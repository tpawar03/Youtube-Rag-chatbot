# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenAI key for RAGAS evaluation (if not using local Ollama as judge)
# OPENAI_API_KEY=sk-...

# Data Paths (defaults are fine for most setups)
# DATA_DIR=./data
# TRANSCRIPTS_DIR=./data/transcripts
# INDICES_DIR=./data/indices

# Webshare rotating residential proxies — used to bypass YouTube IP bans
# on transcript fetches. Leave unset for direct (unproxied) requests.
# Get credentials at https://www.webshare.io/ → Dashboard → Proxy → Settings.
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
